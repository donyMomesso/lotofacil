{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lotofacil",
  "main": "worker.js",
  "compatibility_date": "2026-07-04",
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "0 1 * * *"
    ]
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*",
      "/painel_jogos",
      "/painel_jogos.html"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lotofacil-db",
      "database_id": "580d9d7e-9ab2-4b41-8fc2-b371fbf2bcdc"
    }
  ]
}
